{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "jsx": "react-jsx",
    "types": [
      "bun-types"
    ],
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "electrobun.config.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
